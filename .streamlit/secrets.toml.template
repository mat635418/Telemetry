# ── Streamlit secrets — DO NOT commit real credentials ──────────────────────
# Copy this file to .streamlit/secrets.toml and replace the placeholders with
# your real credentials.  secrets.toml is listed in .gitignore and must never
# be committed.
# When deploying on Streamlit Community Cloud, enter these values via the
# "Secrets" panel in the app settings instead of using a local file.

[auth]
username = "REPLACE_WITH_YOUR_USERNAME"
password = "REPLACE_WITH_YOUR_PASSWORD"
